# 환경변수 예시. 이 파일을 복사해 .env 로 만들고 실제 값을 채운다.  (cp .env.example .env)
# .env 는 Django 시작 시 자동 로드된다 (config/settings.py 의 load_dotenv).
# (.env 자체는 .gitignore 로 제외되어 GitHub에 올라가지 않는다.)

# ── Supabase 뉴스 자동 동기화 (collect_news_supabase) ──
# Supabase 대시보드 → Settings → API 에서 확인
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...   # anon public 키 (또는 service_role)

# Django 비밀키 — 아래 명령으로 새로 생성해 넣을 것:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=여기에-새로-생성한-비밀키-붙여넣기

# 운영 모드 (0=운영, 1=개발). 서버에서는 반드시 0
DJANGO_DEBUG=0

# 접속 허용 도메인/IP (쉼표 구분). 서버의 공인 IP 또는 도메인
DJANGO_ALLOWED_HOSTS=서버공인IP,도메인
