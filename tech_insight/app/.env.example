# 운영 서버 환경변수 예시.
# 이 파일을 복사해 .env 로 만들고 실제 값을 채운 뒤,
# 서버 실행 전에 `export $(cat .env | xargs)` 등으로 적용한다.
# (.env 자체는 .gitignore 로 제외되어 GitHub에 올라가지 않는다.)

# Django 비밀키 — 아래 명령으로 새로 생성해 넣을 것:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=여기에-새로-생성한-비밀키-붙여넣기

# 운영 모드 (0=운영, 1=개발). 서버에서는 반드시 0
DJANGO_DEBUG=0

# 접속 허용 도메인/IP (쉼표 구분). 서버의 공인 IP 또는 도메인
DJANGO_ALLOWED_HOSTS=서버공인IP,도메인
